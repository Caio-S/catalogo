# Use a connection string do "Connection Pooling" do Supabase (modo Session, porta 5432),
# não a conexão direta (db.xxx.supabase.co) — ela é IPv6-only e falha em redes sem IPv6.
DATABASE_URL=postgresql://postgres.xxxxx:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres
SECRET_KEY=troque-esta-chave
